# ============================================
# Forge — Git Ignore
# ============================================

# === Credentials & secrets (NEVER commit) ===
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json
secrets/

# === Personal overrides (per-user) ===
.claude/settings.local.json
.claude/state/
.claude/memory/
.claude/forge-sync-state.json

# === OS files ===
.DS_Store
Thumbs.db
desktop.ini
*Zone.Identifier

# === Large binary files ===
*.zip
*.tar.gz
*.rar
*.7z
*.mp4
*.mov
*.avi
*.psd
*.ai

# === Temp files ===
*.tmp
*.swp
*~

# === Node / Python ===
node_modules/
__pycache__/
*.pyc
.venv/

# === Tool artifacts ===
.playwright-mcp/
generated_imgs/

# === Personal-only features (not shared) ===
.claude/commands/yt.md
.claude/commands/yt-analyze.md
.claude/skills/yt/
.claude/skills/yt-analyze/
shared/scripts/yt-analyzer/

# === Script logs (per-user) ===
shared/scripts/daily-review/logs/
shared/scripts/weekly-research/logs/
