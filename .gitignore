# ============================================
# Forge — Git Ignore
# ============================================

# === Credentials & secrets (NEVER commit) ===
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json
secrets/

# === MCP & API config (contains secrets/endpoints) ===
.mcp.json
.nano-banana-config.json

# === Personal overrides (per-user) ===
.claude/settings.local.json
.claude/state/
.claude/memory/
.claude/forge-sync-state.json
.claude/usage.log
.claude/agent-budget/
.claude/scheduled_tasks.lock

# === OS files ===
.DS_Store
Thumbs.db
desktop.ini
*Zone.Identifier

# === Large binary files ===
*.zip
*.tar.gz
*.rar
*.7z
*.mp4
*.mov
*.avi
*.psd
*.ai

# === Document files (outputs → forge-outputs only, forge is public) ===
*.docx
*.doc
*.hwp
*.hwpx
*.pptx
*.ppt
*.xlsx
*.xls
*.pdf

# === Temp files ===
*.tmp
*.swp
*~

# === Node / Python ===
node_modules/
__pycache__/
*.pyc
.venv/

# === Tool artifacts ===
.playwright-mcp/
generated_imgs/

# === Personal-only features (not shared) ===
.claude/commands/yt.md
.claude/commands/yt-analyze.md
.claude/skills/yt/
.claude/skills/yt-analyze/
shared/scripts/yt-analyzer/

# === Script logs (per-user) ===
shared/scripts/daily-review/logs/
shared/scripts/weekly-research/logs/
