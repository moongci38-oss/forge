      "start": 547.317,
      "duration": 1.733,
      "text": "프롬프트를 여기다가 넣어서"
    },
    {
      "start": 549.05,
      "duration": 1.267,
      "text": "이미지를 생성하고"
    },
    {
      "start": 550.317,
      "duration": 1.667,
      "text": "'업로드해줘'라고 해보겠습니다."
    },
    {
      "start": 551.984,
      "duration": 3.733,
      "text": "아래 프롬프트를 사용해서"
    },
    {
      "start": 555.717,
      "duration": 2.467,
      "text": "'이미지 생성하고 포스팅해줘.'"
    },
    {
      "start": 558.184,
      "duration": 1.5,
      "text": "JSON 프롬프트를"
    },
    {
      "start": 559.684,
      "duration": 2.133,
      "text": "여기다 넣어볼게요."
    },
    {
      "start": 561.817,
      "duration": 2.4,
      "text": "이거 복사(Copy)를 누르시면 됩니다."
    },
    {
      "start": 564.217,
      "duration": 0.833,
      "text": "이 위에 것보다"
    },
    {
      "start": 565.05,
      "duration": 2.9,
      "text": "훨씬 더 높은"
    },
    {
      "start": 567.95,
      "duration": 2.234,
      "text": "퀄리티의 이미지가"
    },
    {
      "start": 570.184,
      "duration": 6.066,
      "text": "생성이 됐고요, 이렇게 생성이 됐고"
    },
    {
      "start": 576.25,
      "duration": 1.334,
      "text": "이미지를 만들고"
    },
    {
      "start": 577.584,
      "duration": 2.6,
      "text": "이렇게 포스팅 텍스트까지 다 썼다고 하네요"
    },
    {
      "start": 580.184,
      "duration": 1.0,
      "text": "다시 한번 볼게요"
    },
    {
      "start": 581.184,
      "duration": 4.833,
      "text": "들어가서 새로고침 눌러보겠습니다"
    },
    {
      "start": 586.017,
      "duration": 2.667,
      "text": "여기에 이렇게 들어갔죠"
    },
    {
      "start": 588.684,
      "duration": 2.166,
      "text": "이미지 나오고"
    },
    {
      "start": 590.85,
      "duration": 4.2,
      "text": "AI로 그리는 극사실주의 시네마틱 포트레이트"
    },
    {
      "start": 595.05,
      "duration": 2.767,
      "text": "이렇게 해서 프롬프트를 어떻게 썼는지까지"
    },
    {
      "start": 597.817,
      "duration": 1.8,
      "text": "다 나왔습니다"
    },
    {
      "start": 599.617,
      "duration": 2.9,
      "text": "여기 보면 태그에 아린(Arin)이 올림이라고 되어"
    },
    {
      "start": 602.517,
      "duration": 0.433,
      "text": "있어요"
    },
    {
      "start": 602.95,
      "duration": 1.2,
      "text": "스마트폰에서도 다시 한번"
    },
    {
      "start": 604.15,
      "duration": 0.734,
      "text": "확인해 보겠습니다"
    },
    {
      "start": 604.884,
      "duration": 3.233,
      "text": "여기서 새로고침 한번 해볼게요"
    },
    {
      "start": 608.117,
      "duration": 0.667,
      "text": "잘 나왔나요?"
    },
    {
      "start": 608.784,
      "duration": 2.133,
      "text": "잘 나왔네요"
    },
    {
      "start": 610.917,
      "duration": 1.433,
      "text": "이렇게 잘 올라왔습니다"
    },
    {
      "start": 612.35,
      "duration": 1.3,
      "text": "이제 이미지 생성하고"
    },
    {
      "start": 613.65,
      "duration": 0.967,
      "text": "업로드까지 하는 거"
    },
    {
      "start": 614.617,
      "duration": 1.367,
      "text": "너무 쉽게 잘 됐잖아요"
    },
    {
      "start": 615.984,
      "duration": 1.6,
      "text": "그냥 한 달 치를"
    },
    {
      "start": 617.584,
      "duration": 1.333,
      "text": "다 만들어 버리고"
    },
    {
      "start": 618.917,
      "duration": 1.9,
      "text": "그다음에 예약 걸고 싶으면"
    },
    {
      "start": 620.817,
      "duration": 0.933,
      "text": "이렇게 하시면 됩니다"
    },
    {
      "start": 621.75,
      "duration": 1.867,
      "text": "지금부터 한 달간"
    },
    {
      "start": 623.617,
      "duration": 1.267,
      "text": "인스타그램 포스팅"
    },
    {
      "start": 624.884,
      "duration": 2.2,
      "text": "매일 하루에 하나씩 해 줘"
    },
    {
      "start": 627.084,
      "duration": 2.3,
      "text": "매일 인터넷을 검색해서"
    },
    {
      "start": 629.384,
      "duration": 1.666,
      "text": "트렌드를 찾고"
    },
    {
      "start": 631.05,
      "duration": 1.767,
      "text": "인스타그램 조회수를"
    },
    {
      "start": 632.817,
      "duration": 1.767,
      "text": "폭발시킬 만한"
    },
    {
      "start": 634.584,
      "duration": 3.1,
      "text": "알고리즘 해킹 방법을 찾아서"
    },
    {
      "start": 637.684,
      "duration": 4.266,
      "text": "그 방법을 사용해서 이미지 생성을 하고"
    },
    {
      "start": 641.95,
      "duration": 2.3,
      "text": "포스팅 텍스트와"
    },
    {
      "start": 644.25,
      "duration": 2.167,
      "text": "태그를 작성해서 올려 줘"
    },
    {
      "start": 646.417,
      "duration": 2.667,
      "text": "시간 또한 분석해서"
    },
    {
      "start": 649.084,
      "duration": 2.333,
      "text": "업로드 시간을 결정해 줘"
    },
    {
      "start": 651.417,
      "duration": 2.933,
      "text": "매일 이것을 할 수 있도록"
    },
    {
      "start": 654.35,
      "duration": 1.967,
      "text": "코드화해서"
    },
    {
      "start": 656.317,
      "duration": 4.567,
      "text": "캘린더에 자동으로 업로드해 줘"
    },
    {
      "start": 660.884,
      "duration": 1.2,
      "text": "이런 식으로 하면 됩니다"
    },
    {
      "start": 662.084,
      "duration": 3.7,
      "text": "이렇게 해서 지금 Day 1부터 Day 30까지"
    },
    {
      "start": 665.784,
      "duration": 2.8,
      "text": "아린이가 스스로 계획을 다 세우고"
    },
    {
      "start": 668.584,
      "duration": 2.033,
      "text": "이미지 생성 플랜도 짜고"
    },
    {
      "start": 670.617,
      "duration": 1.867,
      "text": "텍스트 생성 플랜도 짜고"
    },
    {
      "start": 672.484,
      "duration": 3.2,
      "text": "인터넷을 검색해서 최신 트렌드가 무엇인지"
    },
    {
      "start": 675.684,
      "duration": 2.533,
      "text": "매일매일 그렇게 검색해서 이미지를 생성하고"
    },
    {
      "start": 678.217,
      "duration": 1.5,
      "text": "포스팅하는 것까지"
    },
    {
      "start": 679.717,
      "duration": 1.3,
      "text": "코드화를 시켜 놨습니다."
    },
    {
      "start": 681.017,
      "duration": 1.7,
      "text": "이렇게 코드화를 시켜 놓으면"
    },
    {
      "start": 682.717,
      "duration": 1.267,
      "text": "컴퓨터만 켜져 있으면"
    },
    {
      "start": 683.984,
      "duration": 2.266,
      "text": "알아서 24시간 동안"
    },
    {
      "start": 686.25,
      "duration": 2.167,
      "text": "계속해서 아린(Arin)이 이 일을 하고"
    },
    {
      "start": 688.417,
      "duration": 1.8,
      "text": "지금 이거 올렸다고 팔로우가"
    },
    {
      "start": 690.217,
      "duration": 1.967,
      "text": "한 명 생겼네요."
    },
    {
      "start": 692.184,
      "duration": 2.433,
      "text": "갑자기 안티그래비티가"
    },
    {
      "start": 694.617,
      "duration": 2.133,
      "text": "'사용자의 캘린더에 추가하려고 합니다'라고"
    },
    {
      "start": 696.75,
      "duration": 3.034,
      "text": "뜨면서 알아서 캘린더가 떴고요,"
    },
    {
      "start": 699.784,
      "duration": 1.0,
      "text": "허용을 누르니까"
    },
    {
      "start": 700.784,
      "duration": 1.333,
      "text": "'아린 포스트'해서"
    },
    {
      "start": 702.117,
      "duration": 2.1,
      "text": "16일 오후 7시에"
    },
    {
      "start": 704.217,
      "duration": 2.3,
      "text": "인스타그램 포스팅을 할 거예요."
    },
    {
      "start": 706.517,
      "duration": 1.933,
      "text": "17일에는 오후 8시에"
    },
    {
      "start": 708.45,
      "duration": 1.467,
      "text": "포스팅을 할 거예요."
    },
    {
      "start": 709.917,
      "duration": 3.1,
      "text": "이런 식으로 아린이가 알고리즘을 폭발시키기 위해서"
    },
    {
      "start": 713.017,
      "duration": 2.633,
      "text": "트렌드를 검색하고 그 키워드로"
    },
    {
      "start": 715.65,
      "duration": 1.467,
      "text": "이미지를 생성하고"
    },
    {
      "start": 717.117,
      "duration": 3.767,
      "text": "적절한, 최적화된 시간에 업로드를 하고"
    },
    {
      "start": 720.884,
      "duration": 2.3,
      "text": "이것을 모두 가능하게 하는"
    },
    {
      "start": 723.184,
      "duration": 1.566,
      "text": "코드를 작성했습니다."
    },
    {
      "start": 724.75,
      "duration": 2.0,
      "text": "그러면 아무것도 하지 않아도"
    },
    {
      "start": 726.75,
      "duration": 1.567,
      "text": "컴퓨터만 켜놓게 되면"
    },
    {
      "start": 728.317,
      "duration": 2.267,
      "text": "24시간 아린이가 일을 하게 되고"
    },
    {
      "start": 730.584,
      "duration": 1.566,
      "text": "인스타그램 포스팅까지"
    },
    {
      "start": 732.15,
      "duration": 1.234,
      "text": "알아서 자동으로 하는 거죠."
    },
    {
      "start": 733.384,
      "duration": 1.766,
      "text": "AI 1인 기업의 핵심은"
    },
    {
      "start": 735.15,
      "duration": 1.634,
      "text": "사람이 사용하는 시간을"
    },
    {
      "start": 736.784,
      "duration": 1.366,
      "text": "최소화해야 된다는 겁니다."
    },
    {
      "start": 738.15,
      "duration": 1.434,
      "text": "이게 AI 에이전트로"
    },
    {
      "start": 739.584,
      "duration": 2.8,
      "text": "인스타그램 마케팅하는 것의 시작, 기초입니다."
    },
    {
      "start": 742.384,
      "duration": 1.066,
      "text": "오늘은 제가"
    },
    {
      "start": 743.45,
      "duration": 2.967,
      "text": "인스타그램 자동화 AI 에이전트를 만들고"
    },
    {
      "start": 746.417,
      "duration": 3.0,
      "text": "자동으로 포스팅하는 방법까지 알려드렸는데요,"
    },
    {
      "start": 749.417,
      "duration": 0.533,
      "text": "이걸로 할 수"
    },
    {
      "start": 749.95,
      "duration": 1.434,
      "text": "있는 게 정말 많거든요."
    },
    {
      "start": 751.384,
      "duration": 1.5,
      "text": "영상 생성하는 것,"
    },
    {
      "start": 752.884,
      "duration": 2.966,
      "text": "쪽지 자동으로 보내는 것, 마케팅하는 것 등"
    },
    {
      "start": 755.85,
      "duration": 1.067,
      "text": "정말 많아서"
    },
    {
      "start": 756.917,
      "duration": 2.733,
      "text": "앞으로 하나하나 알려드리도록 하겠습니다."
    },
    {
      "start": 759.65,
      "duration": 1.667,
      "text": "이렇게 AI 자동화 에이전트로"
    },
    {
      "start": 761.317,
      "duration": 1.833,
      "text": "운영되는 1인 기업에 대해서"
    },
    {
      "start": 763.15,
      "duration": 2.067,
      "text": "더 심도 있게 배우고 싶다면"
    },
    {
      "start": 765.217,
      "duration": 1.833,
      "text": "저희 유튜브 멤버십이나"
    },
    {
      "start": 767.05,
      "duration": 0.4,
      "text": "아니면"
    },
    {
      "start": 767.45,
      "duration": 3.067,
      "text": "AI시티 빌더스 강의를 참고하시기 바랍니다."
    }
  ],
  "source": "api"
}