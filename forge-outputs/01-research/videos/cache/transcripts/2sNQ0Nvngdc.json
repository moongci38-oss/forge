    },
    {
      "start": 251.48,
      "duration": 4.039,
      "text": "저는 클로드 코드를 이런 식으로"
    },
    {
      "start": 253.519,
      "duration": 3.321,
      "text": "CC라고 하는 이름으로 단축어로 켜"
    },
    {
      "start": 255.519,
      "duration": 2.96,
      "text": "놓을 수 있도록 설정을 했거든요."
    },
    {
      "start": 256.84,
      "duration": 3.399,
      "text": "그래서 여러분들도 클로드 켜실 때"
    },
    {
      "start": 258.479,
      "duration": 3.401,
      "text": "항상 클로드 이렇게 켜시는게 아니라"
    },
    {
      "start": 260.239,
      "duration": 3.081,
      "text": "뭐 여러분들이 편하신 대로 쓰실 수"
    },
    {
      "start": 261.88,
      "duration": 3.36,
      "text": "있도록 단축어를 지정해 주셔도"
    },
    {
      "start": 263.32,
      "duration": 3.52,
      "text": "되겠습니다. 그래서 그건 클로드가 잘"
    },
    {
      "start": 265.24,
      "duration": 3.6,
      "text": "알려주이니까 그렇게 하시면 되겠고요."
    },
    {
      "start": 266.84,
      "duration": 3.639,
      "text": "이렇게 해서 클로드 코드를 열게"
    },
    {
      "start": 268.84,
      "duration": 4.199,
      "text": "되면은 이제 우리가 할 일은"
    },
    {
      "start": 270.479,
      "duration": 4.121,
      "text": "무엇이냐면 아까 우리가 가져온 깃터브"
    },
    {
      "start": 273.039,
      "duration": 3.521,
      "text": "주소를 여기다 복사 붙여 넣게 하는"
    },
    {
      "start": 274.6,
      "duration": 4.0,
      "text": "것이죠. 한번가 볼게요. 네. 이렇게"
    },
    {
      "start": 276.56,
      "duration": 4.04,
      "text": "해서 저희 기터이 있는 주소를"
    },
    {
      "start": 278.6,
      "duration": 3.8,
      "text": "여기다가 그걸 가지고 복사해서"
    },
    {
      "start": 280.6,
      "duration": 5.28,
      "text": "클로드보드에 붙여 넣습니다. 이렇게"
    },
    {
      "start": 282.4,
      "duration": 7.079,
      "text": "하면은 이걸 가지고이 스킬을 가지고"
    },
    {
      "start": 285.88,
      "duration": 6.44,
      "text": "인테리어 업체 소개를 위한 웹사이트를"
    },
    {
      "start": 289.479,
      "duration": 4.641,
      "text": "하나 만들어 주세요라고 하면은이"
    },
    {
      "start": 292.32,
      "duration": 3.92,
      "text": "스킬을 얘가 복재해서 갖고 옵니다."
    },
    {
      "start": 294.12,
      "duration": 4.0,
      "text": "그거 함께 보도록 해 볼게요. 네."
    },
    {
      "start": 296.24,
      "duration": 3.76,
      "text": "처음으로 이렇게 웹사이트를 만든 걸"
    },
    {
      "start": 298.12,
      "duration": 3.639,
      "text": "볼 수가 있는데요. 전체적으로 보면은"
    },
    {
      "start": 300.0,
      "duration": 4.36,
      "text": "상당히 깔끔합니다. 테이스트 스킬"
    },
    {
      "start": 301.759,
      "duration": 4.241,
      "text": "기반으로 된이 홈페이지가 생각보다"
    },
    {
      "start": 304.36,
      "duration": 3.279,
      "text": "약간 스타일이 어느 정도 좀 정해져"
    },
    {
      "start": 306.0,
      "duration": 3.24,
      "text": "있긴 하거든요. 그런 부분에 있어서"
    },
    {
      "start": 307.639,
      "duration": 3.761,
      "text": "어떤 초한 웹사이트를 만든다고"
    },
    {
      "start": 309.24,
      "duration": 3.6,
      "text": "하더라도 아, 좀 느낌은 좀 있다라는"
    },
    {
      "start": 311.4,
      "duration": 3.2,
      "text": "그런 느낌을 전달해 주는 것"
    },
    {
      "start": 312.84,
      "duration": 3.68,
      "text": "같습니다. 그리고 한국어로 제가 좀"
    },
    {
      "start": 314.6,
      "duration": 4.039,
      "text": "현지화를 해 놨기 때문에이 프레다드"
    },
    {
      "start": 316.52,
      "duration": 3.959,
      "text": "폰트 같은 것들도 잘 들어갔다라고 볼"
    },
    {
      "start": 318.639,
      "duration": 4.041,
      "text": "수가 있는 것이죠. 지금부터 저는 좀"
    },
    {
      "start": 320.479,
      "duration": 4.401,
      "text": "뭘 할 생각이냐면 이제 여기에 히어로"
    },
    {
      "start": 322.68,
      "duration": 4.6,
      "text": "섹션이라고 하죠.이 이 상단 부분에"
    },
    {
      "start": 324.88,
      "duration": 4.52,
      "text": "있는 그 부분을 동영상 스크롤"
    },
    {
      "start": 327.28,
      "duration": 4.6,
      "text": "애니메이션으로 교체할 예정이고 그리고"
    },
    {
      "start": 329.4,
      "duration": 4.4,
      "text": "이미지 부분들은 지금 대충 얘가 아무"
    },
    {
      "start": 331.88,
      "duration": 4.039,
      "text": "이미지나 넣었거든요. 그래서 그런"
    },
    {
      "start": 333.8,
      "duration": 4.119,
      "text": "부분들을 좀 교체를 해서 실제"
    },
    {
      "start": 335.919,
      "duration": 4.0,
      "text": "포트폴리오 웹사이트처럼 한번 만들어"
    },
    {
      "start": 337.919,
      "duration": 4.361,
      "text": "보려고 합니다. 그럼 여기서부터 우리"
    },
    {
      "start": 339.919,
      "duration": 3.84,
      "text": "어디를 가야 되느냐? 그다음 파트는"
    },
    {
      "start": 342.28,
      "duration": 2.88,
      "text": "재미나이를 함께가 보겠습니다."
    },
    {
      "start": 343.759,
      "duration": 3.121,
      "text": "재미나이에 오게 되면 여기서 뭘 해야"
    },
    {
      "start": 345.16,
      "duration": 2.84,
      "text": "되냐면 여기서 동영상 만들기를"
    },
    {
      "start": 346.88,
      "duration": 3.24,
      "text": "여러분들이 선택을 해 주셔야"
    },
    {
      "start": 348.0,
      "duration": 4.88,
      "text": "되거든요. 근데이 동영상을 만들기"
    },
    {
      "start": 350.12,
      "duration": 4.32,
      "text": "전에 우리가 인테리어 업체에 맞는"
    },
    {
      "start": 352.88,
      "duration": 3.4,
      "text": "이미지 레퍼런스를 하나 전달을 해"
    },
    {
      "start": 354.44,
      "duration": 4.039,
      "text": "주고 그에 맞는 샘플 이미지를 함께"
    },
    {
      "start": 356.28,
      "duration": 3.759,
      "text": "만들어 보는 것이 좀 더 빠르고"
    },
    {
      "start": 358.479,
      "duration": 3.041,
      "text": "좋습니다. 그러니까 뭐 인테리어"
    },
    {
      "start": 360.039,
      "duration": 3.72,
      "text": "업체에 필요한 이미지 하나 생성해"
    },
    {
      "start": 361.52,
      "duration": 3.959,
      "text": "줘라고 하기보다는 우리가 별도의"
    },
    {
      "start": 363.759,
      "duration": 2.921,
      "text": "이미지를 검색하고 주는게 훨씬 더"
    },
    {
      "start": 365.479,
      "duration": 3.081,
      "text": "낫다는 것이죠. 한번 그렇게 해"
    },
    {
      "start": 366.68,
      "duration": 3.919,
      "text": "볼게요. 저는 이미지 검색을 위해서"
    },
    {
      "start": 368.56,
      "duration": 4.4,
      "text": "이렇게 핀터레스트에 자주 가보는"
    },
    {
      "start": 370.599,
      "duration": 5.16,
      "text": "합니다. 지금 보면은이 핀터레스트에"
    },
    {
      "start": 372.96,
      "duration": 4.72,
      "text": "이렇게 도착을 했는데 여기서 인테리어"
    },
    {
      "start": 375.759,
      "duration": 4.16,
      "text": "디자인이라고 이렇게 검색을 잠깐 해"
    },
    {
      "start": 377.68,
      "duration": 4.4,
      "text": "볼게요. 그러면은 이렇게 상당히 뭐"
    },
    {
      "start": 379.919,
      "duration": 3.801,
      "text": "소파가 잘 되어 있고 은은한 분위기에"
    },
    {
      "start": 382.08,
      "duration": 3.04,
      "text": "이런 인테리어 이미지들이 상당히 많이"
    },
    {
      "start": 383.72,
      "duration": 3.68,
      "text": "나오는 걸 볼 수가 있습니다. 그렇게"
    },
    {
      "start": 385.12,
      "duration": 4.199,
      "text": "해서 요거를 가지고 우리가 이미지"
    },
    {
      "start": 387.4,
      "duration": 3.56,
      "text": "복사를 해서 가져오는 것이죠. 그러면"
    },
    {
      "start": 389.319,
      "duration": 3.761,
      "text": "저작권의 문제가 걸리지 않느냐라는"
    },
    {
      "start": 390.96,
      "duration": 4.16,
      "text": "부분이 있을 텐데 AI는 저작권을"
    },
    {
      "start": 393.08,
      "duration": 3.839,
      "text": "제가 알기로는 잘 피해 가는 형태로"
    },
    {
      "start": 395.12,
      "duration": 3.28,
      "text": "잘 만들어 주기는 합니다. 특히 이런"
    },
    {
      "start": 396.919,
      "duration": 3.441,
      "text": "재미나이 같은 이런 대기업 AI"
    },
    {
      "start": 398.4,
      "duration": 3.96,
      "text": "서비스 같은 경우에는 이런 부분에"
    },
    {
      "start": 400.36,
      "duration": 3.119,
      "text": "있어서 좀 많은 어 보정이 잘 돼"
    },
    {
      "start": 402.36,
      "duration": 2.88,
      "text": "있다라고 볼 수가 있는 것이죠."
    },
    {
      "start": 403.479,
      "duration": 4.081,
      "text": "이렇게 해서 여러분들이 여기서 이렇게"
    },
    {
      "start": 405.24,
      "duration": 4.16,
      "text": "딱 붙여 넣기를 하고요. 여기서"
    },
    {
      "start": 407.56,
      "duration": 3.479,
      "text": "동영상 만들기 선택을 한 다음에"
    },
    {
      "start": 409.4,
      "duration": 2.76,
      "text": "프롬프트를 넣는 것입니다. 그래서"
    },
    {
      "start": 411.039,
      "duration": 4.16,
      "text": "일단 프론프트만 먼저 보여"
    },
    {
      "start": 412.16,
      "duration": 6.719,
      "text": "드릴게요.이 이미지를 바탕으로 천천히"
    },
    {
      "start": 415.199,
      "duration": 6.56,
      "text": "화면이 돌아가는 동영상을 하나 16대"
    },
    {
      "start": 418.879,
      "duration": 4.641,
      "text": "9 비율로 생성해 줘라고 얘기해 보는"
    },
    {
      "start": 421.759,
      "duration": 3.56,
      "text": "것입니다. 이렇게 하게 됐을 때 이제"
    },
    {
      "start": 423.52,
      "duration": 3.88,
      "text": "여러분들이 빠른 모델이 아니라 또"
    },
    {
      "start": 425.319,
      "duration": 3.681,
      "text": "프로 선택하면 좋고요. 그렇게 해서"
    },
    {
      "start": 427.4,
      "duration": 3.519,
      "text": "도구 선택하고 동영상 만들기 선택을"
    },
    {
      "start": 429.0,
      "duration": 3.24,
      "text": "하면은 어떤 형태로 나오냐? 제가"
    },
    {
      "start": 430.919,
      "duration": 2.761,
      "text": "이미 하나 만들어 놓은게 있습니다."
    },
    {
      "start": 432.24,
      "duration": 3.239,
      "text": "이런 식으로 하나 만들었습니다."
    },
    {
      "start": 433.68,
      "duration": 4.16,
      "text": "그래서 제가 넣은 샘플 이미지는 약간"
    },
    {
      "start": 435.479,
      "duration": 5.041,
      "text": "이런 형태 느낌이었는데요. 이제 이런"
    },
    {
      "start": 437.84,
      "duration": 4.919,
      "text": "느낌이 그라운드 뷰로 천천히 재생되는"
    },
    {
      "start": 440.52,
      "duration": 4.72,
      "text": "랜딩 페이지 히어로에 넣을 영상 하나"
    },
    {
      "start": 442.759,
      "duration": 4.201,
      "text": "생성. 이런 식으로 프롬포트를 넣었고"
    },
    {
      "start": 445.24,
      "duration": 3.48,
      "text": "영상이 준비되었습니다라고 이제 제시해"
    },
    {
      "start": 446.96,
      "duration": 3.84,
      "text": "준 결과물은 이와 같습니다. 그래서"
    },
    {
      "start": 448.72,
      "duration": 3.599,
      "text": "생각보다 굉장히 멋있는 동영상이"
    },
    {
      "start": 450.8,
      "duration": 3.0,
      "text": "생성이 된 걸 볼 수가 있죠."
    },
    {
      "start": 452.319,
      "duration": 3.16,
      "text": "그러면은 요거를 어떻게 하느냐?"
    },
    {
      "start": 453.8,
      "duration": 3.399,
      "text": "저희는 이거를 저장을 합니다. 이렇게"
    },
    {
      "start": 455.479,
      "duration": 3.641,
      "text": "저장을 해서 저장을 하게 되면은"
    },
    {
      "start": 457.199,
      "duration": 3.761,
      "text": "저희가 지금 이게 그라운드 뷰 영상"
    },
    {
      "start": 459.12,
      "duration": 3.799,
      "text": "생성 요청이라고 하는 파일이 저희가"
    },
    {
      "start": 460.96,
      "duration": 3.72,
      "text": "만든 폴더에 저장이 되겠죠. 그러면"
    },
    {
      "start": 462.919,
      "duration": 4.521,
      "text": "이렇게 저장을 누르고요. 저장된"
    },
    {
      "start": 464.68,
      "duration": 4.919,
      "text": "동영상을 저희가 만든이 웹사이트"
    },
    {
      "start": 467.44,
      "duration": 4.159,
      "text": "있잖아요.이 웹사이트에 이렇게 붙여"
    },
    {
      "start": 469.599,
      "duration": 5.201,
      "text": "넣어 주는게 중요합니다. 그러니까"
    },
    {
      "start": 471.599,
      "duration": 6.921,
      "text": "이거를 끌어서 이렇게 넣어 주고이"
    },
    {
      "start": 474.8,
      "duration": 6.839,
      "text": "영상을 히어로 섹션에 넣어 주고 크롤"
    },
    {
      "start": 478.52,
      "duration": 4.959,
      "text": "애니메이션이 적용되게 해 줘라고 하는"
    },
    {
      "start": 481.639,
      "duration": 5.201,
      "text": "것이죠. 이렇게 한 다음에 크롤"
    },
    {
      "start": 483.479,
      "duration": 6.641,
      "text": "애니메이션은 웹피 파일로 견환해서"
    },
    {
      "start": 486.84,
      "duration": 7.079,
      "text": "만들어 줘. 부드러운 애니메이션이 될"
    },
    {
      "start": 490.12,
      "duration": 5.72,
      "text": "수 있도록 꼭 신경 써서 해 줘라고"
    },
    {
      "start": 493.919,
      "duration": 3.68,
      "text": "얘기해 주는게 중요합니다. 그리고"
    },
    {
      "start": 495.84,
      "duration": 5.079,
      "text": "그다음에 해야 될 일은 무엇이냐?"
    },
    {
      "start": 497.599,
      "duration": 6.88,
      "text": "나머지 이미지들 또한 인테리어"
    },
    {
      "start": 500.919,
      "duration": 5.081,
      "text": "웹사이트에 걸맞도록 교체해 줘라고"
    },
    {
      "start": 504.479,
      "duration": 2.881,
      "text": "하는 것이죠. 이렇게 한번 제작을 해"
    },
    {
      "start": 506.0,
      "duration": 3.319,
      "text": "보도록 지시를 해 볼게요. 자,"
    },
    {
      "start": 507.36,
      "duration": 3.72,
      "text": "이렇게 되면은 우리가 이제 인테리어"
    },
    {
      "start": 509.319,
      "duration": 3.481,
      "text": "디자인이라고 하는이 파일이 하나"
    },
    {
      "start": 511.08,
      "duration": 3.199,
      "text": "생성이 되는데요. 여기 ACTML"
