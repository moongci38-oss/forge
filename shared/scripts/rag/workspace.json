      "note": "Forge 시스템 (rules/skills/agents/templates)"
    },
    {
      "path": "${FORGE_OUTPUTS:-~/forge-outputs}",
      "exclude_dirs": [
        ".git", "__pycache__", ".rag-index",
        "06-finance", "07-legal",
        "08-admin/insurance", "08-admin/freelancers"
      ],
      "note": "Forge 산출물 (민감 폴더 제외)"
    },
    {
      "path": "~/mywsl_workspace/portfolio-project",
      "exclude_dirs": [
        ".git", "node_modules", ".next", "dist", "out", "build",
        ".turbo", "coverage", ".jest-cache"
      ],
      "note": "Portfolio 프로젝트 문서/설정 (소스는 INCLUDE_EXTS 화이트리스트로 자동 제외)"
    },
    {
      "path": "/mnt/e/new_workspace/god_Sword",
      "exclude_dirs": [
        ".git", "Library", "Temp", "obj", "Logs",
        "UserSettings", "Packages", "ProjectSettings/GraphicsSettings.asset"
