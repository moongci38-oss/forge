{
  "version": "1.0.0",
  "workspaces": {
    "wsl": {
      "description": "WSL Linux 프로젝트",
      "basePath": "{YOUR_WSL_WORKSPACE}"
    },
    "windows": {
      "description": "Windows 프로젝트",
      "basePath": "{YOUR_WINDOWS_WORKSPACE}"
    }
  },
  "targets": {
    "portfolio": {
      "path": "{YOUR_PORTFOLIO_PATH}",
      "scope": "all",
      "description": "Next.js + NestJS 포트폴리오 플랫폼",
      "workspace": "wsl"
    },
    "godblade": {
      "path": "{YOUR_GAME_PROJECT_PATH}",
      "scope": "all",
      "description": "Unity 게임 프로젝트 (C#)",
      "workspace": "windows"
    }
  }
}
